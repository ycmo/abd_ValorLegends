  "human_review_rules": [
    {
      "rule_id": "ERR_NOT_ON_DAILY_TASKS",
      "trigger_condition": "Daily Tasks page verification fails during startup or check (confidence < 0.85).",
      "action": "Trigger STOPPED_FOR_HUMAN_REVIEW, take manual review screenshot, and halt execution."
    },
    {
      "rule_id": "ERR_MATCH_GRAY_ZONE",
      "trigger_condition": "Template matching confidence is in the gray zone (0.6 <= confidence < 0.85).",
      "action": "Trigger STOPPED_FOR_HUMAN_REVIEW, take manual review screenshot, and halt execution."
    },
    {
      "rule_id": "ERR_DEDUPLICATION_GRAY_ZONE",
      "trigger_condition": "Task label comparison similarity is in the gray zone (0.85 <= max_val < 0.92).",
      "action": "Trigger STOPPED_FOR_HUMAN_REVIEW, take manual review screenshot, and halt execution."
    },
    {
      "rule_id": "ERR_NO_BUTTONS_ON_PAGE_1",
      "trigger_condition": "Page scan on Page 1 detects 0 active Go buttons.",
      "action": "Trigger STOPPED_FOR_HUMAN_REVIEW, take manual review screenshot, and halt execution."
    },
    {
      "rule_id": "ERR_RETURN_NAVIGATION_FAILED",
      "trigger_condition": "Failed to return to the Daily Tasks page after executing all return/recovery sequences.",
      "action": "Trigger STOPPED_FOR_HUMAN_REVIEW, take manual review screenshot, and halt execution."
    },
    {
      "rule_id": "ERR_RESOURCE_RISK",
      "trigger_condition": "Potential consumption of diamonds, gold, tickets, or starting battles/upgrades.",
      "action": "Prevent click, trigger STOPPED_FOR_HUMAN_REVIEW, and halt."
    }
  ],
